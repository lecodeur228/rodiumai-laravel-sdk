{
    "name": "rodiumai/laravel-sdk",
    "description": "Laravel/PHP SDK for the RodiumAI API — multi-model AI with Mobile Money payments",
    "type": "library",
    "license": "MIT",
    "keywords": ["rodiumai", "ai", "laravel", "openai", "africa", "llm", "sdk", "chatgpt", "claude"],
    "homepage": "https://www.rodiumai.io/docs",
    "support": {
        "issues": "https://github.com/lecodeur228/rodiumai-laravel-sdk/issues",
        "source": "https://github.com/lecodeur228/rodiumai-laravel-sdk"
    },
    "authors": [
        {
            "name": "Irin (techpastor)",
            "email": "support@rodiumai.io"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "laravel/framework": "12.*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "RodiumAI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RodiumAI\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["RodiumAI\\RodiumAIServiceProvider"],
            "aliases": {
                "RodiumAI": "RodiumAI\\Facades\\RodiumAI"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit",
        "test:smoke": "php bin/smoke-test.php"
    }
}
